# Site URL — must match exactly what's stored in client_configs.site_url in NGF admin
NEXT_PUBLIC_SITE_URL=westmiwindowtint.com

# NGF app (content API) — leave as-is unless overriding
NGF_APP_URL=https://app.ngfsystems.com

# Revalidation secret — must match WEBSITE_REVALIDATION_SECRET in NGF Vercel env vars
WEBSITE_REVALIDATION_SECRET=your-secret-here

# Quote form — email sent here on submission
RESEND_API_KEY=re_...
QUOTE_RECIPIENT_EMAIL=zach@westmiwindowtint.com
